---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import LocaleRedirect from "../components/LocaleRedirect.astro";
import ProjectChannel from "../components/ProjectChannel.astro";

const projects = (await getCollection("projects", ({ data }) => data.locale === "en" && data.featured))
  .sort((a, b) => a.data.order - b.data.order);

---

<BaseLayout
  title="Liangyi Murong | Applied AI Engineer"
  description="Applied AI engineer and technical leader building production systems across computer vision, multimodal video, generative AI, and spatial computing."
  locale="en"
  className="channel-home"
>
  <LocaleRedirect />
  <ProjectChannel projects={projects} locale="en" />
</BaseLayout>
