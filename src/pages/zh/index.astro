---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProjectChannel from "../../components/ProjectChannel.astro";

const projects = (await getCollection("projects", ({ data }) => data.locale === "zh" && data.featured))
  .sort((a, b) => a.data.order - b.data.order);

---

<BaseLayout
  title="慕容良一｜应用 AI 工程师"
  description="应用 AI 工程师与技术负责人，专注计算机视觉、多模态视频、生成式 AI、空间计算及生产系统落地。"
  locale="zh"
  className="channel-home"
>
  <ProjectChannel projects={projects} locale="zh" />
</BaseLayout>
