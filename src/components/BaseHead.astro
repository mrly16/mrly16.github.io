---
interface Props {
  title: string;
  description: string;
  locale: "en" | "zh";
  pathname: string;
  image?: string;
}

const {
  title,
  description,
  locale,
  pathname,
  image = "/og-default.svg"
} = Astro.props;

const canonical = new URL(pathname, Astro.site);
const alternatePath =
  locale === "en"
    ? pathname === "/"
      ? "/zh/"
      : `/zh${pathname}`
    : pathname.replace(/^\/zh/, "") || "/";
const alternate = new URL(alternatePath, Astro.site);
const imageUrl = new URL(image, Astro.site);
const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Liangyi Murong",
  alternateName: "慕容良一",
  url: "https://mrly16.github.io",
  email: "mailto:markmoyung131@gmail.com",
  sameAs: [
    "https://github.com/mrly16",
    "https://www.linkedin.com/in/liangyimurong"
  ],
  jobTitle: "Applied AI Engineer",
  address: {
    "@type": "PostalAddress",
    addressLocality: "Shenzhen",
    addressCountry: "CN"
  }
};
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />
<meta name="description" content={description} />
<meta name="theme-color" content="#f4f0e8" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="canonical" href={canonical} />
<link rel="alternate" hreflang={locale === "en" ? "zh-CN" : "en"} href={alternate} />
<link rel="alternate" hreflang={locale === "en" ? "en" : "zh-CN"} href={canonical} />
<link rel="alternate" hreflang="x-default" href={new URL("/", Astro.site)} />
<meta property="og:type" content="website" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={imageUrl} />
<meta property="og:locale" content={locale === "zh" ? "zh_CN" : "en_US"} />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={imageUrl} />
<script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
<title>{title}</title>
